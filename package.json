{
  "name": "torrent-snag",
  "version": "1.1.0",
  "description": "Chrome extension to detect torrent and magnet links and send them to torrent clients",
  "main": "background.js",
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "build:dev": "node build.js",
    "clean": "rm -rf dist/",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "echo 'Lint script placeholder'",
    "watch": "echo 'Watch mode not implemented yet'"
  },
  "keywords": [
    "chrome-extension",
    "torrent",
    "qbittorrent",
    "magnet-links"
  ],
  "author": "Blackboard Studios",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "moduleFileExtensions": ["js", "json"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blackboardstudios/torrent-snag.git"
  },
  "bugs": {
    "url": "https://github.com/blackboardstudios/torrent-snag/issues"
  },
  "homepage": "https://github.com/blackboardstudios/torrent-snag#readme"
}
